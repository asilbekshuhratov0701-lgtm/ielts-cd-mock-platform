# =============================================================================
# PRODUCTION env template — copy to `apps/web/.env.production` and fill in.
#
#   cp apps/web/.env.production.example apps/web/.env.production
#
# Next.js reads env from apps/web/, so this file MUST live here (not repo root).
# On Vercel/Railway/Render you can instead paste these into the host's secret
# manager and skip the file entirely.
#
# For DB MIGRATIONS the Prisma CLI reads packages/db/.env — create it with just
# the two DB URLs below (DATABASE_URL + DIRECT_URL).
#
# NEVER commit the filled-in .env.production (it's gitignored). See DEPLOYMENT.md.
# =============================================================================

# --- Core [required] ---
NODE_ENV=production
# Public base URL of the deployed app. MUST be correct — password-reset links
# and absolute URLs are built from it.
APP_URL=https://exams.yourcentre.com
APP_NAME="IELTS Mock Platform"

# --- Database (Postgres, e.g. Neon) [required] ---
# Pooled connection (host usually contains "-pooler") — used by the running app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
# Direct (non-pooled) connection — used by Prisma for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# --- Auth (Auth.js / NextAuth v5) [required] ---
# Generate: `npx auth secret`  or  `openssl rand -base64 32`
AUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_STRING"
AUTH_TRUST_HOST=true
SESSION_MAX_AGE_DAYS=7
SESSION_REMEMBER_ME_DAYS=30

# --- Object storage (Cloudflare R2) ---
# [required for Vercel / Path B] Leave ALL blank on Path A (disk-backed host with
# a persistent volume at apps/web/public/media) — media then writes to disk.
# All four of ACCOUNT_ID/ACCESS_KEY_ID/SECRET/BUCKET must be set to use R2.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="ielts-media"
# Public read URL for the bucket (r2.dev URL or a custom domain). Media is served
# from ${R2_PUBLIC_BASE_URL}/<key>.
R2_PUBLIC_BASE_URL="https://media.yourcentre.com"

# --- Email (Resend) ---
# [required for self-service password reset] If RESEND_API_KEY is blank, reset
# emails are skipped (logged, not sent) and admins reset passwords manually.
RESEND_API_KEY=""
# Must be an address on a Resend-verified domain.
EMAIL_FROM="IELTS Platform <noreply@yourcentre.com>"

# --- AI exam import (Anthropic Claude) [optional] ---
# Without a key, AI PDF import runs in mock mode.
ANTHROPIC_API_KEY=""
AI_MODEL_PRIMARY=claude-opus-4-8
AI_MODEL_FAST=claude-sonnet-4-6

# --- Background worker / Redis [optional] ---
# Only needed if you run apps/worker (scoring runs inline without it).
REDIS_URL=""
WORKER_CONCURRENCY=4
FINALIZE_CRON="*/1 * * * *"

# --- Observability [optional] ---
SENTRY_DSN=""
LOG_LEVEL=info
