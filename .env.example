# =============================================================================
# IELTS Platform — environment template. Copy to `.env` and fill in real values.
# NEVER commit a real .env. All secrets live in the platform secret manager in prod.
# =============================================================================

# --- Core ---
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME="IELTS Mock Platform"

# --- Database (Neon / Supabase Postgres) ---
# Pooled connection string for the app (serverless-safe via PgBouncer/Neon pooler).
DATABASE_URL="postgresql://ielts:ielts@localhost:5432/ielts?schema=public"
# Direct (non-pooled) connection for Prisma migrations.
DIRECT_URL="postgresql://ielts:ielts@localhost:5432/ielts?schema=public"

# --- Redis (Upstash) — cache, rate limiting, BullMQ queues ---
REDIS_URL="redis://localhost:6379"
# Upstash REST (optional, for serverless rate-limit SDK)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Auth (Auth.js / NextAuth v5) ---
AUTH_SECRET="change-me-generate-a-long-random-string"
AUTH_TRUST_HOST=true
SESSION_MAX_AGE_DAYS=7
SESSION_REMEMBER_ME_DAYS=30

# --- Object storage (Cloudflare R2 — S3 compatible) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="ielts-media"
R2_PUBLIC_BASE_URL=""
MEDIA_SIGNED_URL_TTL_SECONDS=300

# --- AI provider (Anthropic Claude) ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=""
AI_MODEL_PRIMARY=claude-opus-4-8
AI_MODEL_FAST=claude-sonnet-4-6
# Optional OCR
OCR_PROVIDER=tesseract
AWS_TEXTRACT_REGION=""

# --- Email (Resend / Postmark) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=""
EMAIL_FROM="IELTS Platform <noreply@example.com>"

# --- Observability ---
SENTRY_DSN=""
LOG_LEVEL=info

# --- Worker ---
WORKER_CONCURRENCY=4
FINALIZE_CRON="*/1 * * * *"
